<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1920 1080">
  <rect width="100%" height="100%" fill="#050505"/>
  <!-- Neural network nodes -->
  <circle cx="200" cy="200" r="8" fill="#ff0000" opacity="0.8"/>
  <circle cx="400" cy="150" r="6" fill="#ff3333" opacity="0.7"/>
  <circle cx="600" cy="250" r="10" fill="#ff0000" opacity="0.9"/>
  <circle cx="800" cy="180" r="7" fill="#ff3333" opacity="0.8"/>
  <circle cx="1000" cy="220" r="9" fill="#ff0000" opacity="0.8"/>
  <circle cx="1200" cy="160" r="8" fill="#ff3333" opacity="0.7"/>
  <circle cx="1400" cy="200" r="6" fill="#ff0000" opacity="0.8"/>
  <circle cx="1600" cy="180" r="7" fill="#ff3333" opacity="0.7"/>
  
  <circle cx="300" cy="400" r="9" fill="#ff0000" opacity="0.8"/>
  <circle cx="500" cy="380" r="7" fill="#ff3333" opacity="0.7"/>
  <circle cx="700" cy="420" r="8" fill="#ff0000" opacity="0.9"/>
  <circle cx="900" cy="360" r="10" fill="#ff3333" opacity="0.8"/>
  <circle cx="1100" cy="400" r="6" fill="#ff0000" opacity="0.8"/>
  <circle cx="1300" cy="380" r="8" fill="#ff3333" opacity="0.7"/>
  <circle cx="1500" cy="420" r="7" fill="#ff0000" opacity="0.8"/>
  
  <!-- Connections -->
  <line x1="200" y1="200" x2="400" y2="150" stroke="#ff0000" stroke-width="2" opacity="0.6"/>
  <line x1="400" y1="150" x2="600" y2="250" stroke="#ff0000" stroke-width="2" opacity="0.6"/>
  <line x1="600" y1="250" x2="800" y2="180" stroke="#ff0000" stroke-width="2" opacity="0.6"/>
  <line x1="800" y1="180" x2="1000" y2="220" stroke="#ff0000" stroke-width="2" opacity="0.6"/>
  <line x1="1000" y1="220" x2="1200" y2="160" stroke="#ff0000" stroke-width="2" opacity="0.6"/>
  <line x1="1200" y1="160" x2="1400" y2="200" stroke="#ff0000" stroke-width="2" opacity="0.6"/>
  <line x1="1400" y1="200" x2="1600" y2="180" stroke="#ff0000" stroke-width="2" opacity="0.6"/>
  
  <line x1="300" y1="400" x2="500" y2="380" stroke="#ff0000" stroke-width="2" opacity="0.6"/>
  <line x1="500" y1="380" x2="700" y2="420" stroke="#ff0000" stroke-width="2" opacity="0.6"/>
  <line x1="700" y1="420" x2="900" y2="360" stroke="#ff0000" stroke-width="2" opacity="0.6"/>
  <line x1="900" y1="360" x2="1100" y2="400" stroke="#ff0000" stroke-width="2" opacity="0.6"/>
  <line x1="1100" y1="400" x2="1300" y2="380" stroke="#ff0000" stroke-width="2" opacity="0.6"/>
  <line x1="1300" y1="380" x2="1500" y2="420" stroke="#ff0000" stroke-width="2" opacity="0.6"/>
  
  <!-- Vertical connections -->
  <line x1="200" y1="200" x2="300" y2="400" stroke="#ff0000" stroke-width="1" opacity="0.4"/>
  <line x1="600" y1="250" x2="700" y2="420" stroke="#ff0000" stroke-width="1" opacity="0.4"/>
  <line x1="1000" y1="220" x2="1100" y2="400" stroke="#ff0000" stroke-width="1" opacity="0.4"/>
  <line x1="1400" y1="200" x2="1500" y2="420" stroke="#ff0000" stroke-width="1" opacity="0.4"/>
  
  <!-- Central OASIS text -->
  <text x="960" y="540" text-anchor="middle" fill="#ff0000" font-family="Orbitron" font-size="80" font-weight="bold" opacity="0.8">AI NETWORK</text>
</svg>